# Copy to .env (gitignored). Never commit the real key.
# Butterbase personal API key with scope ai:gateway — used by the eval harness only.
# The deployed app never sees this; serverless functions use their own injected creds.
BUTTERBASE_API_KEY=bb_sk_...

# Optional overrides
# BUTTERBASE_API_URL=https://api.butterbase.ai
# MILO_MODEL=anthropic/claude-sonnet-4.6
